# Bunny Stream — server only (do not use NEXT_PUBLIC_* for the API key)
# Copy to Vercel → Project → Settings → Environment Variables for Production
# Stream → your library → API / Library ID / CDN hostname

BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=

# Optional: kanonisk nettadresse (https://ditt-domene.no) for Open Graph / metadataBase.
# Anbefalt hvis Facebook skal hente opengraph.jpg fra produksjon, ikke fra preview-URL.
# NEXT_PUBLIC_SITE_URL=
